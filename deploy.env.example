# Copy to deploy.env on the VPS (deploy.env is gitignored).
# Used by: docker compose -f docker-compose.prod.yml --env-file deploy.env up -d --build

# Public site — credit.zokm.me served on host port 5465 → container 3001
DOMAIN=credit.zokm.me
WEB_PORT=5465

# Next.js proxies /api/v1/* to the internal API service (do not expose API port publicly)
API_PROXY_URL=http://api:8001

# Leave empty so the browser uses same-origin /api/v1 (proxied by Next.js)
NEXT_PUBLIC_API_URL=

# FastAPI — internal only; CORS is a fallback if the API is hit directly
API_WORKERS=2
CORS_ORIGINS=https://credit.zokm.me,http://credit.zokm.me:5465
