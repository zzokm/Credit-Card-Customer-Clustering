# Production build — copy to dashboard/.env.production
# Leave empty when Next.js proxies /api/v1 to FastAPI (Docker + credit.zokm.me).
# Set only if the browser must call a separate API origin.
NEXT_PUBLIC_API_URL=

# Server-side rewrite target (set at Docker build via API_PROXY_URL build arg).
# API_PROXY_URL=http://api:8001
